    { "source": "/products/", "destination": "/index.html" },
    { "source": "/contact-us", "destination": "/index.html" },
    { "source": "/contact-us/", "destination": "/index.html" },
    { "source": "/careers", "destination": "/index.html" },
    { "source": "/careers/", "destination": "/index.html" },
    { "source": "/blog", "destination": "/index.html" },
    { "source": "/blog/", "destination": "/index.html" }
  ]
